{
  "name": "nexus-command",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": ["shared", "server", "client", "functions"],
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "build": "tsc -b && pnpm --filter client build",
    "test": "pnpm --filter server test && pnpm --filter shared test",
    "test:server": "pnpm --filter server test",
    "test:client": "pnpm --filter client test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
